# Copy to .env and fill in. .env is gitignored.

# GitHub user whose public activity feeds the weekly digest.
GITHUB_USER=davisweilun

# Where Claude Code stores session logs (default shown).
CLAUDE_PROJECTS_DIR=/Users/dw/.claude/projects

# Activity score below this => "thin" week (web-enriched); 0 => "none".
MIN_ACTIVITY_SCORE=2

# Discord webhook for draft notifications (Server Settings -> Integrations -> Webhooks).
DISCORD_WEBHOOK_URL=

# LinkedIn app (developer.linkedin.com). Run `bash scripts/linkedin.sh auth` once to fill
# LINKEDIN_REFRESH_TOKEN and LINKEDIN_PERSON_URN.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8765/callback
LINKEDIN_API_VERSION=202506
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ACCESS_EXPIRES=
LINKEDIN_PERSON_URN=
